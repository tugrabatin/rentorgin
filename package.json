{
  "name": "basis",
  "version": "0.5.0",
  "description": "BASIS - Enterprise Rental Management Platform - Kurumsal Kiralama Yönetim Platformu",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "db:migrate": "cd packages/database && npx prisma migrate dev",
    "db:seed": "cd packages/database && npx prisma db seed",
    "db:studio": "cd packages/database && npx prisma studio",
    "api:dev": "cd apps/api && npm run start:dev",
    "web:dev": "cd apps/web && npm run dev",
    "vercel:deploy": "cd apps/web && npx vercel --prod",
    "vercel:dev": "cd apps/web && npx vercel dev"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "vercel": "^50.1.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tugrabatin/rentorgin"
  },
  "keywords": [
    "rental",
    "lease",
    "management",
    "enterprise",
    "saas",
    "ai-powered"
  ],
  "author": "BASIS Team",
  "license": "PROPRIETARY"
}
